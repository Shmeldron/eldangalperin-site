# --- Site ---
# Public base URL (set on Vercel once the domain is live).
NEXT_PUBLIC_SITE_URL=https://eldangalperin.com

# --- AI assistant (optional; the widget degrades gracefully if absent) ---
# Set EITHER key to enable the chat assistant. If both are set, OpenAI wins.
# OpenAI (default model: gpt-5-mini — a reasoning model)
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5-mini          # or gpt-5.4-mini (newer), gpt-4o-mini (non-reasoning)
# GPT-5 is a reasoning model: hidden reasoning tokens draw from the output
# budget, so the ceiling must be generous (a tiny cap → empty replies).
# OPENAI_MAX_COMPLETION_TOKENS=1500
# Effort trades latency for depth; "minimal" keeps a scoped Q&A bot snappy.
# OPENAI_REASONING_EFFORT=minimal  # minimal | low | medium | high (gpt-5-mini has no "none")
#
# Anthropic (default model: a cheap/fast Haiku)
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Guardrails (sensible defaults applied if unset)
# AI_RATE_LIMIT_PER_MIN=8     # burst cap per IP
# AI_RATE_LIMIT_PER_DAY=30    # per-IP daily cap — stops one abuser draining the monthly budget
# AI_MONTHLY_REQUEST_CAP=1500

# --- Durable rate limiting / budget cap (recommended for production) ---
# Without these, limits are best-effort in-memory (per serverless instance).
# Create a free Upstash Redis DB (Vercel Marketplace) and paste its REST creds.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# --- Lead capture (the chat widget's "Share your email" affordance) ---
# Capture is enabled when at least ONE sink is configured; otherwise the
# affordance shows a "use the contact section" fallback.
# Sink 1 — email via Resend (recommended; you get the lead instantly):
# RESEND_API_KEY=
# LEAD_FROM_EMAIL=leads@yourdomain.com   # must be a Resend-verified sender
# LEAD_TO_EMAIL=you@yourdomain.com       # where leads are delivered
# Sink 2 — durable backup log: reuses UPSTASH_REDIS_* above (Redis list eg:leads).
# Stricter per-IP rate limit for the lead endpoint (default 3/min):
# LEAD_RATE_LIMIT_PER_MIN=3
